# Minimal public repository allowlist
# Keep the first commit limited to application source, maintained tooling,
# Gradle build essentials, project rules, and sanitized setup templates.
/*
!/.gitignore
!/.gitattributes
!/AGENTS.md
!/LICENSE
!/README.md
!/app/
!/tools/
!/gradle/
!/gradlew
!/gradlew.bat
!/build.gradle.kts
!/settings.gradle.kts
!/gradle.properties
!/keystore.properties.example
!/local.properties.example
