# Copy to keystore.properties (git-ignored) and fill in.
# Create the keystore once, then BACK IT UP — every future Y2Player update must
# be signed with this same key or the device will refuse to upgrade the package.
#
#   keytool -genkeypair -v -keystore y2player-release.jks \
#           -alias y2player -keyalg RSA -keysize 2048 -validity 10000
#
# Android 4.4 requires a v1 (JAR) signature; RSA-2048 with SHA-256 is fine.
storeFile=y2player-release.jks
storePassword=******
keyAlias=y2player
keyPassword=*******
